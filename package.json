{
  "name": "i18n-key-validator",
  "displayName": "i18n Key Validator",
  "description": "Validates i18n translation keys in HTML/TS files against locale JSON files. Supports ngx-translate and similar i18n setups.",
  "publisher": "RamiroCR98",
  "version": "2.0.2",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:html",
    "onLanguage:typescript",
    "onLanguage:json"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "ngx-translate i18n Validator",
      "properties": {
        "i18nKV.localesPath": {
          "type": "string",
          "default": "src/assets/i18n",
          "description": "Path to locale folder relative to workspace root. Must contain {locale}/{namespace}.json files."
        },
        "i18nKV.sourceLocale": {
          "type": "string",
          "default": "es",
          "description": "Source locale used to validate keys (e.g. 'es')."
        },
        "i18nKV.severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ],
          "default": "error",
          "description": "Diagnostic severity for missing i18n keys."
        }
      }
    },
    "commands": [
      {
        "command": "i18nKV.reload",
        "title": "i18nKV: Reload locale files"
      },
      {
        "command": "i18nKV.openLocaleFile",
        "title": "i18nKV: Open locale file"
      },
      {
        "command": "i18nKV.createKey",
        "title": "i18nKV: Create missing key in all locales"
      },
      {
        "command": "i18nKV.showTable",
        "title": "i18nKV: Show i18n Key Table"
      }
    ]
  }
}
